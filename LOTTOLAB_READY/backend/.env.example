# ========================================
# LOTTOLAB BACKEND - CONFIGURATION
# ========================================
# INSTRUCTIONS:
# 1. Copiez ce fichier: cp .env.example .env
# 2. Modifiez JWT_SECRET_KEY avec une clé unique!

# MongoDB Connection
MONGO_URL=mongodb://localhost:27017
DB_NAME=lottolab

# JWT Security - CHANGEZ CETTE CLÉ!
JWT_SECRET_KEY=votre-cle-secrete-unique-minimum-32-caracteres-CHANGEZ-MOI

# CORS - Domaines autorisés
CORS_ORIGINS=https://lottolab.tech,https://www.lottolab.tech,http://localhost:3000
