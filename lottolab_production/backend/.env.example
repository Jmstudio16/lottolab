# ========================================
# LOTTOLAB BACKEND - CONFIGURATION
# ========================================
# 1. Copiez ce fichier: cp .env.example .env
# 2. Modifiez les valeurs ci-dessous

# MongoDB Connection
MONGO_URL="mongodb://localhost:27017"
DB_NAME="lottolab"

# JWT Security - CHANGEZ CETTE CLÉ EN PRODUCTION!
JWT_SECRET_KEY="votre-cle-secrete-tres-longue-minimum-32-caracteres-changez-moi"

# CORS - Domaines autorisés (séparés par virgule)
CORS_ORIGINS="https://lottolab.tech,https://www.lottolab.tech"
