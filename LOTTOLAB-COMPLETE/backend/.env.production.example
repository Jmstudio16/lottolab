# LOTTOLAB - Configuration de Production
# Copier ce fichier vers .env et remplir les valeurs

# MongoDB - Remplacer par votre URL de production avec authentification
MONGO_URL="mongodb://utilisateur:mot_de_passe@localhost:27017/lottolab_production?authSource=admin"
DB_NAME="lottolab_production"

# JWT - OBLIGATOIRE: Générer une clé sécurisée de 64+ caractères
# Utilisez: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY="REMPLACER_PAR_UNE_CLE_SECURISEE_DE_64_CARACTERES_MINIMUM"

# CORS - Remplacer par votre(vos) domaine(s) exact(s)
# Séparer plusieurs domaines par des virgules, sans espaces
CORS_ORIGINS="https://votre-domaine.com,https://www.votre-domaine.com"
