# ========================================
# LOTTOLAB BACKEND - CONFIGURATION
# ========================================
# Copiez ce fichier en .env et modifiez les valeurs

# MongoDB
MONGO_URL="mongodb://localhost:27017"
DB_NAME="lottolab"

# Sécurité JWT - CHANGEZ CETTE CLÉ EN PRODUCTION !
JWT_SECRET_KEY="CHANGEZ-CETTE-CLE-SECRETE-EN-PRODUCTION-MINIMUM-32-CARACTERES"

# CORS - Domaines autorisés (séparés par virgule)
CORS_ORIGINS="https://lottolab.tech,https://www.lottolab.tech"
